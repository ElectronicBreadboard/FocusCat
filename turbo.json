{
	"$schema": "https://turborepo.com/schema.json",
	"ui": "tui",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"inputs": ["$TURBO_DEFAULT$", ".env*"],
			"outputs": ["dist/**", "build/**"]
		},
		"clean": {
			"cache": false
		},
		"lint": {
			"dependsOn": ["^lint"]
		},
		"start:dev": {
			"cache": false,
			"persistent": true
		},
		"test": {
			"cache": false
		},
		"update:latest": {
			"cache": false
		}
	}
}
