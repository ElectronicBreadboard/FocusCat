{
	"name": "@repo/ui",
	"version": "0.0.1",
	"private": true,
	"description": "",
	"keywords": [],
	"bugs": {
		"url": "https://github.com/builder-group/focuscat/issues"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/builder-group/focuscat.git"
	},
	"license": "AGPL-3.0-or-later",
	"author": "@bennobuilder",
	"exports": {
		".": {
			"types": "./dist/types/index.d.ts",
			"source": "./src/index.ts",
			"import": "./dist/esm/index.js",
			"require": "./dist/cjs/index.js",
			"default": "./dist/cjs/index.js"
		},
		"./theme.css": "./dist/theme.css",
		"./tailwind.css": "./dist/tailwind.css"
	},
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"build": "shx rm -rf dist && rollup -c rollup.config.js && pnpm build:css",
		"build:css": "shx cp ./src/styles/theme.css ./dist/theme.css && npx @tailwindcss/cli -i ./src/styles/tailwind.css -o ./dist/tailwind.css",
		"build:prod": "export NODE_ENV=production && pnpm build",
		"clean": "shx rm -rf dist && shx rm -rf .turbo && shx rm -rf node_modules",
		"install:clean": "pnpm run clean && pnpm install",
		"lint": "eslint . --fix",
		"start:dev": "tsc -w && pnpm watch:css",
		"test": "vitest run",
		"update:latest": "pnpm update --latest",
		"watch:css": "shx cp ./src/styles/theme.css ./dist/theme.css && npx @tailwindcss/cli -i ./src/styles/tailwind.css -o ./dist/tailwind.css --watch"
	},
	"dependencies": {
		"@base-ui/react": "^1.3.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"feature-react": "^0.0.67",
		"feature-state": "^0.0.65",
		"lucide-react": "^1.7.0",
		"motion": "^12.38.0",
		"tailwind-merge": "^3.5.0"
	},
	"devDependencies": {
		"@tailwindcss/cli": "^4.2.2",
		"@types/react": "^19.2.14",
		"react": "^19.2.4",
		"tailwindcss": "^4.2.2"
	}
}
